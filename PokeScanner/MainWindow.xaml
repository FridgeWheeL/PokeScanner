<Window x:Class="PokeScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PokeScanner" Icon="pack://siteoforigin:,,,/app.ico" Height="880" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e" Foreground="#e0e0e0">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#16213e" />
            <Setter Property="Foreground" Value="#f5c518" />
            <Setter Property="BorderBrush" Value="#f5c518" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#16213e" />
            <Setter Property="Foreground" Value="#f5c518" />
            <Setter Property="BorderBrush" Value="#f5c518" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontWeight" Value="Bold" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FFD700" />
                    <Setter Property="BorderBrush" Value="#FFD700" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Content" Value="Auto ON" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#f5c518" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0f3460" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#f5c518" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0f3460" />
            <Setter Property="Foreground" Value="#f5c518" />
            <Setter Property="BorderBrush" Value="#f5c518" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0f3460" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#f5c518" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Margin="0,0,0,6"
                 Background="#16213e" BorderBrush="#f5c518" Foreground="#f5c518">
            <Label Content="📷 Camera:" />
            <ComboBox x:Name="CameraSelector" Width="140"
                      SelectionChanged="CameraSelector_SelectionChanged" />
            <Button x:Name="RefreshButton" Content="⟳" Margin="6,0,0,0" Width="28"
                    Click="RefreshButton_Click" />
            <Separator />
            <Label Content="🧠 Model:" />
            <ComboBox x:Name="ModelSelector" Width="200"
                      SelectionChanged="ModelSelector_SelectionChanged" />
            <Separator />
            <ToggleButton x:Name="AutoButton" Content="Auto" Width="55"
                          Checked="AutoButton_Checked" Unchecked="AutoButton_Unchecked" />
        </ToolBar>

        <Border Grid.Row="1" BorderBrush="#f5c518" BorderThickness="2"
                Background="#0a0a1a">
            <Grid>
                <Image x:Name="CameraPreview" Stretch="Uniform" />
                <Rectangle x:Name="RoiOverlay"
                           Stroke="#f5c518" StrokeThickness="2"
                           Fill="#22FFD700"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Width="400" Height="560" />
                <TextBlock Text="Place card inside the gold box, then click Capture"
                           Foreground="#f5c518" FontSize="14" FontWeight="Bold"
                           Background="#AA16213e" Padding="8,4"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="0,0,0,10" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="CaptureButton" Content="⚡ Capture"
                        Width="100" Height="32"
                        Click="CaptureButton_Click" />
                <Button x:Name="ResetButton" Content="↺" Width="32" Height="32"
                        Margin="6,0,0,0"
                        Click="ResetButton_Click" />
            </StackPanel>

            <Border Grid.Row="0" Grid.Column="1" BorderBrush="#f5c518" BorderThickness="1" Margin="10,0"
                    Background="#0f3460">
                <Image x:Name="CroppedPreview" Width="100" Height="140" Stretch="Uniform" />
            </Border>

            <TextBox Grid.Row="0" Grid.Column="2" x:Name="CardInfoText" Height="32"
                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     Text="⚡ Select a camera and position a card..." />

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    BorderBrush="#f5c518" BorderThickness="1" Margin="0,4,0,0"
                    Background="#0a0a1a" Padding="6"
                    MinHeight="100">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               FontSize="11" Foreground="#f5c518"
                               Text="Click a result to select, then Open in Browser:"
                               Margin="0,0,0,4" />
                    <ListBox Grid.Row="1" Grid.Column="0"
                             x:Name="CardResultList"
                             Background="#0f3460" Foreground="#e0e0e0"
                             BorderThickness="0"
                             FontSize="12" FontFamily="Consolas"
                             SelectionChanged="CardResultList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="6,0,0,0">
                        <Button x:Name="CollectrButton"
                                Content="Collectr"
                                Height="28" Width="110"
                                VerticalAlignment="Top"
                                IsEnabled="False"
                                Click="CollectrButton_Click" />
                        <Button x:Name="TcgplayerButton"
                                Content="TCGplayer"
                                Height="28" Width="110"
                                Margin="0,6,0,0"
                                VerticalAlignment="Top"
                                IsEnabled="False"
                                Click="TcgplayerButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="3"
                    Background="#16213e" BorderBrush="#f5c518" BorderThickness="1"
                    Margin="0,6,0,0" Padding="8,6">
                <TextBlock x:Name="StatusText"
                           FontSize="14" FontWeight="Bold" Foreground="#f5c518"
                           Text="Ready" />
            </Border>
        </Grid>
    </Grid>
</Window>